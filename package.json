{
  "name": "zol-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "build:css": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -c ./tailwind.config.cjs -i ./css/custom.css -o ./css/styles.css --minify",
    "dev:css": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -c ./tailwind.config.cjs -i ./css/custom.css -o ./css/styles.css --watch"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "tailwindcss": "3.4.17"
  }
}
